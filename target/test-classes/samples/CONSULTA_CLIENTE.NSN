DEFINE DATA LOCAL
01 CLIENTE-VIEW VIEW OF CLIENTE
  02 CLIENTE-ID
  02 NOME
  02 CPF
  02 STATUS
  02 IDADE
01 #CPF (A11)
01 #VALOR-TOTAL (N10,2)
END-DEFINE

FIND CLIENTE-VIEW WITH CPF = #CPF
  IF STATUS = 'A'
    WRITE 'CLIENTE ATIVO'
  ELSE
    REINPUT 'CLIENTE INATIVO'
  END-IF

  IF IDADE < 18
    REINPUT 'CLIENTE MENOR DE IDADE'
  END-IF

  COMPUTE #VALOR-TOTAL = CLIENTE-ID * 10

  CALLNAT 'VALIDA-CLIENTE' CLIENTE-ID
END-FIND

END
